# Vite bakes VITE_* at build time. In Vercel → Settings → Environment Variables add the same keys for Production (and Preview). Redeploy after saving. Do not set VITE_BASE unless the site is served from a subpath (not normal for *.vercel.app).
VITE_SUPABASE_URL=https://ylwuxtnuqqsivoaiybaw.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlsd3V4dG51cXFzaXZvYWl5YmF3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgyNDk1OTksImV4cCI6MjA5MzgyNTU5OX0.imXjy3NcEhVXmRXir8p423yE__5JRGYZ1H7g0oDoOxU
# Auth email redirects use the live site URL automatically in production builds.
# Optional DEV ONLY — override signup redirect when testing (e.g. ngrok). Do not set on Vercel.
# VITE_AUTH_REDIRECT_URL=http://localhost:5173/login
#
# In Supabase → Authentication → URL Configuration add your live URLs, e.g.:
#   Site URL: https://your-app.vercel.app
#   Redirect URLs: https://your-app.vercel.app/login
#                   https://your-app.vercel.app/auth/confirm
# If the site lives in a subpath (e.g. GitHub Pages https://user.github.io/tle_brand/), set:
# VITE_BASE=/tle_brand/
# Web Push: run `npm run vapid:keys` — put public key here and in Supabase Edge secret VAPID_PUBLIC_KEY; private key only in Supabase VAPID_PRIVATE_KEY; VAPID_SUBJECT=mailto:you@yourdomain.com
# VITE_VAPID_PUBLIC_KEY=
# Optional: same origin as production (also storable in Admin → Account). Edge secret PUBLIC_APP_URL overrides DB if set.
# PUBLIC_APP_URL=https://your-app.vercel.app
#
# Optional: canonical https URL so Open Graph/Twitter previews use an absolute logo image URL.
# VITE_SITE_URL=https://your-app.vercel.app
