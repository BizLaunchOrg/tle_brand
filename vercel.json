{
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/shop", "destination": "/index.html" },
    { "source": "/checkout", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" },
    { "source": "/makeup", "destination": "/index.html" },
    { "source": "/book", "destination": "/index.html" },
    { "source": "/auth/(.*)", "destination": "/index.html" },
    { "source": "/product/(.*)", "destination": "/index.html" }
  ]
}
